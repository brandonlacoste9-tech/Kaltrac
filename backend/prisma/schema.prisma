// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  
  settings      Settings?
  meals         Meal[]
  workouts      Workout[]
  waterLogs     WaterLog[]
  favorites     Favorite[]
  shoppingItems ShoppingItem[]
  receipts      Receipt[]

  @@map("users")
}

model Settings {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id              String    @unique @db.Uuid
  daily_calorie_goal   Int?      @default(2000)
  daily_protein_goal   Int?      @default(150)
  daily_carbs_goal     Int?      @default(250)
  daily_fat_goal       Int?      @default(65)
  daily_water_goal     Int?      @default(8)
  dietary_restrictions String[]  @default([])
  language             String?   @default("en") @db.VarChar(10)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)
  
  user                 User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("settings")
}

model Meal {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String?   @db.Uuid
  name          String    @db.VarChar(255)
  calories      Int
  protein       Decimal?  @default(0) @db.Decimal(6, 1)
  carbs         Decimal?  @default(0) @db.Decimal(6, 1)
  fat           Decimal?  @default(0) @db.Decimal(6, 1)
  fiber         Decimal?  @default(0) @db.Decimal(6, 1)
  sugar         Decimal?  @default(0) @db.Decimal(6, 1)
  meal_type     String?   @default("tracked") @db.VarChar(50)
  source        String?   @default("manual") @db.VarChar(50)
  notes         String?
  image_url     String?
  barcode       String?   @db.VarChar(50)
  ingredients   Json?     @default("[]")
  logged_at     DateTime? @default(now()) @db.Timestamptz(6)
  
  user          User?     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("meals")
}

model Workout {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String?   @db.Uuid
  exercise_name    String    @db.VarChar(255)
  duration_minutes Int
  calories_burned  Int
  intensity        String?   @default("moderate") @db.VarChar(20)
  notes            String?
  logged_at        DateTime? @default(now()) @db.Timestamptz(6)
  
  user             User?     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("workouts")
}

model WaterLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String?  @db.Uuid
  log_date      DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  glasses_count Int?     @default(0)
  
  user          User?    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, log_date])
  @@map("water_logs")
}

model Favorite {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String?   @db.Uuid
  name          String    @db.VarChar(255)
  calories      Int
  protein       Decimal?  @default(0) @db.Decimal(6, 1)
  carbs         Decimal?  @default(0) @db.Decimal(6, 1)
  fat           Decimal?  @default(0) @db.Decimal(6, 1)
  notes         String?
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  
  user          User?     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("favorites")
}

model ShoppingItem {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id              String?   @db.Uuid
  barcode              String?   @db.VarChar(50)
  product_name         String    @db.VarChar(255)
  brand                String?   @db.VarChar(255)
  image_url            String?
  calories_per_serving Int?
  nutriscore_grade     String?   @db.VarChar(1)
  nova_group           Int?
  is_checked           Boolean?  @default(false)
  added_at             DateTime? @default(now()) @db.Timestamptz(6)
  
  user                 User?     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("shopping_list")
}

model Receipt {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String?   @db.Uuid
  store_name   String?   @db.VarChar(255)
  total_amount Decimal?  @db.Decimal(10, 2)
  currency     String?   @default("CAD") @db.VarChar(10)
  items        Json?     @default("[]")
  image_url    String?
  scanned_at   DateTime? @default(now()) @db.Timestamptz(6)
  receipt_date DateTime? @db.Date
  notes        String?
  category     String?   @default("General") @db.VarChar(100)
  
  user         User?     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("receipts")
}

model GroceryScanCache {
  barcode      String   @id @db.VarChar(50)
  product_data Json
  cached_at    DateTime @default(now()) @db.Timestamptz(6)

  @@map("grocery_scan_cache")
}
