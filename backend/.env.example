DATABASE_URL=postgresql://user:password@host/database
JWT_SECRET=your-secret-key-change-in-production
PORT=5000
FRONTEND_URL=http://localhost:5173

# Optional AI providers
# - If GEMINI_API_KEY is set, KalTrac uses Gemini Flash as the primary AI.
# - Otherwise it will try Ollama locally (OLLAMA_URL), then fall back to sample/manual data.
GEMINI_API_KEY=
OLLAMA_URL=http://localhost:11434/api/chat

# Stripe (Premium: $9.99/mo with 7-day free trial)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
# Optional: use a Stripe Payment Link URL instead of API Checkout (e.g. https://buy.stripe.com/...)
STRIPE_PAYMENT_LINK_URL=
# Optional: Stripe Payment Link ID (plink_...) for reference / API lookups
STRIPE_PAYMENT_LINK_ID=
# Optional overrides (otherwise FRONTEND_URL is used)
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
